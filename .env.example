NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=true

# Supabase is optional for local demo mode. Use the SQL in /supabase when enabling hosted persistence.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Scanner safety. Keep false outside controlled local development.
ACCESSAUDIT_ALLOW_PRIVATE_NETWORK=false
ACCESSAUDIT_MAX_PAGES=30
ACCESSAUDIT_SCAN_CONCURRENCY=1
ACCESSAUDIT_RATE_LIMIT_MS=750

# Optional artifact storage location. Defaults to .accessaudit/artifacts.
ACCESSAUDIT_ARTIFACT_DIR=
