NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=true

# Supabase is optional for local demo mode. Use the SQL in /supabase when enabling hosted persistence.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ACCESS_AUDIT_STORAGE_BUCKET=access-audit-artifacts

# Production queue. Railway/Render Redis usually provides REDIS_URL automatically.
REDIS_URL=

# Scanner safety. Keep false outside controlled local development.
ACCESS_AUDIT_ALLOW_PRIVATE_NETWORK=false
ACCESS_AUDIT_MAX_PAGES=30
ACCESS_AUDIT_SCAN_CONCURRENCY=1
ACCESS_AUDIT_RATE_LIMIT_MS=750

# Optional artifact storage location. Defaults to .access-audit/artifacts.
ACCESS_AUDIT_ARTIFACT_DIR=
