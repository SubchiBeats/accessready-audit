{
  "name": "access-audit",
  "version": "0.1.0",
  "private": true,
  "description": "Access Audit: a hosted accessibility audit workspace for scans, evidence, remediation tracking, and risk reports.",
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:web": "node scripts/start-web.mjs",
    "start:worker": "tsx scripts/scan-worker.ts",
    "healthcheck": "node scripts/healthcheck.mjs",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "accessibility:self-check": "playwright test tests/e2e/a11y.spec.ts"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@supabase/supabase-js": "^2.49.1",
    "axe-core": "^4.10.3",
    "bullmq": "^5.34.1",
    "clsx": "^2.1.1",
    "ioredis": "^5.4.2",
    "lucide-react": "^0.468.0",
    "next": "^15.3.5",
    "playwright": "^1.49.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "tsx": "^4.19.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.3.5",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.11"
  }
}
